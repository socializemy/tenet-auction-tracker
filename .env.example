# ============================================================
# Spokane Auction Properties — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Database (leave blank to use local SQLite) ---
DATABASE_URL=sqlite:///./auction_data.db
# For PostgreSQL on VPS use:
# DATABASE_URL=postgresql://auctionuser:yourpassword@localhost/auctiondb

# --- Quality Loan credentials ---
QUALITY_LOAN_USER=CoJames1
QUALITY_LOAN_PASS=HJK4*#&90

# --- InsourceLogic credentials (optional — skip if not available) ---
INSOURCE_USER=
INSOURCE_PASS=

# --- VPS deployment settings (used by deploy.sh) ---
VPS_HOST=your-vps-ip-or-hostname
VPS_USER=root
VPS_DEPLOY_PATH=/var/www/spokane-auction
DOMAIN=your-domain.com
